#!/usr/bin/env ruby

require 'exifr/jpeg'
require 'time'

SUPPORTED_EXTS = %w[.jpg .jpeg .png .gif .bmp]

def print_separator
  puts "-" * 60
end

# Esta función lee los bytes binarios directamente para extraer metadatos
# sin necesidad de usar exiftool ni gemas adicionales. ¡Muy estilo 42!
def extract_custom_metadata(filepath, ext)
  puts "\n[ Internal Header Metadata ]"
  File.open(filepath, 'rb') do |f|
    case ext
    when '.png'
      header = f.read(8)
      if header == "\x89PNG\r\n\x1a\n".b
        f.read(4) # Saltamos la longitud del chunk IHDR
        if f.read(4) == "IHDR"
          # Extraemos Ancho, Alto, Profundidad de bits y Tipo de color
          width, height, bit_depth, color_type = f.read(10).unpack('NNCC')
          puts format("%-20s : %s px", "Image Width", width)
          puts format("%-20s : %s px", "Image Height", height)
          puts format("%-20s : %s bits", "Bit Depth", bit_depth)
          puts format("%-20s : %s", "Color Type", color_type)
        end
      else
        puts "❌ Invalid PNG header."
      end
    when '.gif'
      header = f.read(6)
      if %w[GIF89a GIF87a].include?(header)
        # Extraemos Ancho y Alto (Little Endian)
        width, height = f.read(4).unpack('vv')
        puts format("%-20s : %s", "GIF Version", header)
        puts format("%-20s : %s px", "Image Width", width)
        puts format("%-20s : %s px", "Image Height", height)
      else
        puts "❌ Invalid GIF header."
      end
    when '.bmp'
      header = f.read(2)
      if header == "BM"
        f.read(16) # Saltamos el tamaño del archivo y bytes reservados
        # Extraemos Ancho y Alto (Little Endian de 32 bits)
        width, height = f.read(8).unpack('VV')
        puts format("%-20s : %s", "Format", "Windows Bitmap (BMP)")
        puts format("%-20s : %s px", "Image Width", width)
        puts format("%-20s : %s px", "Image Height", height)
      else
        puts "❌ Invalid BMP header."
      end
    end
  end
rescue => e
  puts "❌ Error reading binary metadata: #{e.message}"
end

def process_image(filepath)
  print_separator
  puts "🔍 Analyzing: #{filepath}"

  unless File.exist?(filepath)
    puts "❌ Error: File not found."
    return
  end

  ext = File.extname(filepath).downcase
  unless SUPPORTED_EXTS.include?(ext)
    puts "⚠️ Warning: Extension '#{ext}' is not officially supported."
  end

  # --- 1. Atributos Básicos del Sistema ---
  begin
    stat = File.stat(filepath)
    puts "\n[ Basic File Attributes ]"
    puts format("%-20s : %s", "File Extension", ext)
    puts format("%-20s : %s bytes", "File Size", stat.size)
    
    creation_time = stat.respond_to?(:birthtime) ? stat.birthtime : stat.ctime
    puts format("%-20s : %s", "Created On", creation_time)
    puts format("%-20s : %s", "Last Modified", stat.mtime)
  rescue => e
    puts "❌ Error reading basic attributes: #{e.message}"
  end

  # --- 2. Metadatos Específicos según Extensión ---
  if %w[.jpg .jpeg].include?(ext)
    puts "\n[ EXIF Data ]"
    begin
      exif_obj = EXIFR::JPEG.new(filepath)
      if exif_obj.exif?
        exif_data = exif_obj.exif.to_hash.compact
        exif_data.delete(:thumbnail) # Limpiamos basura binaria
        
        if exif_data.empty?
          puts "No readable EXIF tags found."
        else
          exif_data.each do |key, value|
            display_value = value.to_s.length > 80 ? "#{value.to_s[0..77]}..." : value
            puts format("%-20s : %s", key, display_value)
          end
        end
      else
        puts "No EXIF block found in this JPEG."
      end
    rescue EXIFR::MalformedJPEG
      puts "❌ Error: Malformed JPEG file."
    rescue => e
      puts "❌ Error reading EXIF: #{e.message}"
    end
  elsif %w[.png .gif .bmp].include?(ext)
    # Llamamos a nuestro extractor binario personalizado
    extract_custom_metadata(filepath, ext)
  end
  
  print_separator
end

def main
  if ARGV.empty?
    puts "Usage: ./scorpion FILE1 [FILE2 ...]"
    exit 1
  end

  ARGV.each do |file|
    process_image(file)
  end
end

main
